NODE_ENV=development
PORT=3013
MONGODB_URI=mongodb://localhost:27017/flora-docassemble

# DocAssemble Configuration (Self-Hosted)
# Point to your self-hosted DocAssemble instance on Railway
DOCASSEMBLE_URL=https://docassemble-app-production.up.railway.app
DOCASSEMBLE_API_KEY=your_api_key_from_docassemble_admin

# Service Base URL (for callbacks from DocAssemble)
# This should be the public URL where this service is accessible
SERVICE_BASE_URL=https://flora-docassemble-service-production.up.railway.app

# Callback Security (optional)
# If DocAssemble supports callback signatures, set this secret
DOCASSEMBLE_CALLBACK_SECRET=your_callback_secret_here

# Sync Service Configuration
# Enable/disable background sync service
ENABLE_SYNC_SERVICE=true
# Sync interval in milliseconds (default: 5 minutes)
SYNC_INTERVAL_MS=300000

# Document Download Configuration
# Set to 'true' to download and backup DocAssemble documents to S3
DOWNLOAD_DOCASSEMBLE_DOCS=false

# AWS S3 Configuration (use Flora's S3 bucket)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=flora-documents

# JWT Authentication
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h

# Service Configuration
MAX_FILE_SIZE=10485760
SIGNED_URL_EXPIRY=3600

# Optional: Read-only PostgreSQL access for debugging
# POSTGRES_READ_URL=postgresql://USER:PASSWORD@HOST:PORT/docassemble?schema=public
